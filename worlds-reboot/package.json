{
  "name": "playforge-worlds-reboot",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "audit:touch": "node tools/audit-touch.mjs",
    "test:golf:phase2": "node tools/golf.phase2.mjs",
    "test:golf:phase2:candidate": "node tools/golf.phase2.mjs --candidate",
    "test:foundation:unit": "node --test tools/foundation.unit.test.mjs",
    "test:foundation:browser": "node tools/foundation.browser.mjs",
    "test:foundation": "npm run test:foundation:unit && npm run test:foundation:browser",
    "test:post:browser": "node tools/post.browser.mjs",
    "test:post:watchdog-negative": "node --test --test-timeout=30000 tools/post.browser.watchdog.test.mjs",
    "test:post": "npm run test:post:browser && npm run test:post:watchdog-negative",
    "test:runner:unit": "node --test --test-timeout=30000 tools/runner.sim.unit.test.mjs tools/runner.geometry.unit.test.mjs tools/runner.handle-scope.unit.test.mjs",
    "test:runner:cue": "node --test --test-timeout=30000 tools/runner.cue.unit.test.mjs",
    "test:runner:browser": "node tools/shipcheck-runner.mjs --browser-only",
    "test:runner:phase3": "node tools/shipcheck-runner.mjs",
    "test:runner:phase3:candidate": "node tools/shipcheck-runner.mjs --candidate",
    "test:runner:watchdog-negative": "node --test --test-timeout=15000 tools/runner.hard-gate.watchdog.test.mjs",
    "test:runner:phase4": "node tools/shipcheck-phase4.mjs",
    "test:runner:phase4:dev": "node tools/shipcheck-phase4.mjs --dev",
    "test:runner:phase4:negative": "node --test --test-concurrency=1 --test-timeout=300000 tools/phase-group-finalizer.test.mjs tools/phase-marker-processes.test.mjs tools/browser-containment.test.mjs tools/runner.phase4.process-snapshot.test.mjs tools/phase-spawn-gate.test.mjs tools/phase-isolated-node.integration.test.mjs tools/runner.phase4.watchdog.test.mjs",
    "test:release:watchdog-negative": "node --test --test-timeout=120000 tools/shipcheck-release.watchdog.test.mjs",
    "test:release": "node tools/shipcheck-release.mjs",
    "test:wings:legacy-chrome": "node tools/wings.legacy-chrome.check.mjs"
  },
  "dependencies": {
    "puppeteer": "^25.3.0",
    "three": "^0.185.1",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
